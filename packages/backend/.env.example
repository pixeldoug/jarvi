# Runtime
# Keep NODE_ENV=production for both staging and production deployments.
# Use APP_ENV to distinguish behavior between staging and production.
NODE_ENV=development
APP_ENV=development
PORT=3001

# Database
# Development: sqlite:./jarvi.db
# Staging/Production: postgresql://user:password@host:5432/database
DATABASE_URL=sqlite:./jarvi.db

# Authentication
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_MOBILE_CLIENT_ID=

# CORS
# Comma-separated list of allowed web origins.
# If empty, backend uses defaults from APP_ENV:
# - development: http://localhost:3000,http://localhost:5173,http://localhost:4173
# - staging: https://staging.jarvi.life,https://www.staging.jarvi.life
# - production: https://jarvi.life,https://www.jarvi.life
CORS_ALLOWED_ORIGINS=

# Legacy single-origin variable (optional). Kept for compatibility.
CORS_ORIGIN=

# Chrome extension allowlist.
# Required when NODE_ENV=production.
# Format: comma-separated extension IDs, without chrome-extension:// prefix.
ALLOWED_EXTENSION_IDS=

# Gmail ingestion tuning
GMAIL_INGEST_RATE_LIMIT_MAX=12
GMAIL_INGEST_MAX_BODY_CHARS=12000
OPENAI_TASK_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=

# App URL (emails/links)
APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Resend
RESEND_API_KEY=

# WhatsApp / Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WEBHOOK_URL=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
