{
  "buildCommand": "npm run build:shared && npm run build:web",
  "outputDirectory": "packages/web/dist",
  "framework": "vite",
  "installCommand": "npm install",
  "devCommand": "cd packages/web && npm run dev",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://jarvi-staging.up.railway.app/api/:match*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "",
    "VITE_APP_NAME": "Jarvi"
  }
}
